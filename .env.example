# ============================================================
#  J.A.R.V.I.S. — Configurações de Ambiente
#  Copie este arquivo para .env e ajuste os valores
# ============================================================

# --- Ollama (LLM local) ---
# Host do servidor Ollama (padrão: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Modelo a usar. Opções recomendadas:
#   llama3.2        → 3B parâmetros, rápido, bom para hardware modesto
#   llama3.1:8b     → 8B parâmetros, melhor qualidade
#   mistral         → 7B, ótimo para diálogo
OLLAMA_MODEL=llama3.2

# --- Clima ---
# Cidade para previsão do tempo
JARVIS_CITY=São Paulo

# --- Voz (TTS) ---
# Vozes PT-BR disponíveis: pt-BR-AntonioNeural (masc), pt-BR-FranciscaNeural (fem)
JARVIS_VOICE=pt-BR-AntonioNeural

# --- STT ---
# Tamanho do modelo Whisper: tiny, base, small, medium, large
# base = bom equilíbrio entre velocidade e precisão
WHISPER_MODEL=base
